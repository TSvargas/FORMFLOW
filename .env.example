# =============================================================================
# TypeD V2 — Variáveis de Ambiente (Template)
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
#   cp .env.example .env
#
# NUNCA versione o arquivo .env no Git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=typed_admin
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
POSTGRES_DB=typed_v2
POSTGRES_PORT=5432
DATABASE_URL="postgresql://typed_admin:TROQUE_POR_SENHA_FORTE_AQUI@localhost:5432/typed_v2?schema=public"

# --- API (Backend Fastify) ---
API_PORT=4012
JWT_SECRET=TROQUE_POR_CHAVE_SECRETA_LONGA_AQUI
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:4012

# --- Construída automaticamente pelo Docker Compose ---
# DATABASE_URL=postgresql://typed_admin:SENHA@typed-db:5432/typed_v2?schema=public
